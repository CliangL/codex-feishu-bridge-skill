# Feishu/Lark bot credentials.
# Copy to .env and fill with your own app values. Do not commit .env.
FEISHU_APP_ID=FEISHU_APP_ID
FEISHU_APP_SECRET=FEISHU_APP_SECRET
FEISHU_DOMAIN=feishu
FEISHU_CONNECTION_MODE=websocket

# Optional event verification values if you use webhook mode.
FEISHU_VERIFICATION_TOKEN=
FEISHU_ENCRYPT_KEY=

# Optional notification destination for scheduled jobs.
# Use a Feishu chat_id such as oc_xxx. Leave empty to reply to the source chat.
CODEX_FEISHU_NOTIFY_CHAT_ID=

# Local Codex wiring.
CODEX_HOME=
CODEX_FEISHU_CODEX_BIN=codex
CODEX_FEISHU_WORKSPACE=
CODEX_FEISHU_TASK_POLL_SECONDS=60
CODEX_FEISHU_TIMEZONE=Asia/Shanghai

# Safety and behavior.
CODEX_FEISHU_ALLOWED_USERS=
CODEX_FEISHU_REQUIRE_MENTION=true
CODEX_FEISHU_MAX_MEMORY_TURNS=12
CODEX_FEISHU_MAX_INPUT_CHARS=24000
CODEX_FEISHU_CODEX_ARGS=exec --skip-git-repo-check --dangerously-bypass-approvals-and-sandbox
CODEX_FEISHU_AUTOMATIONS=true
